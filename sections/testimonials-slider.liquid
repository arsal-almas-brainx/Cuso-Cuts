      "id": "fixed_bg_image",
      "label": "Background Decorative Image"
    },
    {
      "type": "range",
      "id": "section_max_width",
      "label": "Max width (px)",
      "min": 600,
      "max": 1600,
      "step": 20,
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_horizontal_left_padding",
      "label": "left padding (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "section_horizontal_right_padding",
      "label": "right padding (%)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Top padding (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 160,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum section height (px)",
