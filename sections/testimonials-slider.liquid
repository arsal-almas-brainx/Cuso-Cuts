{% comment %} sections/testimonials-slider.liquid {% endcomment %}
{%- style -%}
  {{ section.settings.overline_font | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_face: font_display: 'swap' }}
  {{ section.settings.review_count_font | font_face: font_display: 'swap'}}
  {{ section.settings.quote_font | font_face: font_display: 'swap' }}

  {{ section.settings.overline_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ section.settings.body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ section.settings.quote_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
{%- endstyle -%}
<style>
    .tslider-section-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      padding: {{ section.settings.section_padding_top }}px 0 {{ section.settings.section_padding_bottom }}px;
      overflow: hidden;
      position: relative;
    }

    .tslider-wrap-{{ section.id }} {
      max-width: {{ section.settings.section_max_width }}px;
      margin: 0 auto;
      padding-left: {{ section.settings.section_horizontal_left_padding }}%;
      padding-right: {{ section.settings.section_horizontal_right_padding }}%;
    }

    .tslider-inner-{{ section.id }} {
      display: flex;
      align-items: center;
      gap: {{ section.settings.content_gap }}px;
      min-height: {{ section.settings.min_height }}px;
    }

    /* Image column */
    .tslider-image-col-{{ section.id }} {
      flex: 0 0 {{ section.settings.image_col_width }}px;
      width: {{ section.settings.image_col_width }}px;
    }

    .tslider-img-wrap-{{ section.id }} {
      width: {{ section.settings.image_width }}px;
      height: {{ section.settings.image_height }}px;
      border-radius: 0%;
      overflow: hidden;
      position: relative;
    }

    .tslider-img-wrap-{{ section.id }} img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .tslider-img-placeholder-{{ section.id }} {
      width: 100%;
      height: 100%;
      background: #f0ede8;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #aaa;
      font-size: 14px;
    }

    /* Content column */
    .tslider-content-col-{{ section.id }} {
      flex: 1;
      min-width: 0;
    }

    /* Overline */
    .tslider-overline-{{ section.id }} {
      font-family: {{ section.settings.overline_font.family }}, {{ section.settings.overline_font.fallback_families }};
      font-weight: {{ section.settings.overline_font_weight }};
      font-style: {{ section.settings.overline_font.style }};
      font-size: {{ section.settings.overline_font_size }}px;
      color: {{ section.settings.overline_color }};
      letter-spacing: {{ section.settings.overline_letter_spacing }}px;
      text-transform: uppercase;
      margin: 0 0 {{ section.settings.overline_margin_bottom }}px;
    }

    /* Stars row */
    .tslider-stars-row-{{ section.id }} {
      display: flex;
      align-items: center;
      gap: 8px;
      margin-bottom: {{ section.settings.stars_margin_bottom }}%;
      margin-top: {{ section.settings.stars_margin_top }}%;
    }

    .tslider-stars-{{ section.id }} {
      display: flex;
      gap: {{ section.settings.star_gap }}px;
    }

    .tslider-stars-{{ section.id }} svg {
      width: {{ section.settings.star_size }}px;
      height: {{ section.settings.star_size }}px;
    }

    .tslider-review-count-{{ section.id }} {
      font-size: {{ section.settings.review_count_font_size }}px;
      color: {{ section.settings.review_count_color }};
      font-family: {{ section.settings.review_count_font.family }}, {{ section.settings.body_font.fallback_families }};
      font-style: {{ section.settings.review_count_font.style }};
    }

    /* Slides wrapper */
    .tslider-slides-outer-{{ section.id }} {
      overflow: hidden;
      position: relative;
    }

    .tslider-slides-{{ section.id }} {
      display: flex;
      transition: transform {{ section.settings.transition_speed }}ms {{ section.settings.transition_easing }};
    }

    .tslider-slide-{{ section.id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    /* Quote */
    .tslider-quote-{{ section.id }} {
    display: flex;
    flex-direction: column;
  }
    .tslider-quote-{{ section.id }} p {
      font-family: {{ section.settings.quote_font.family }}, {{ section.settings.quote_font.fallback_families }};
      font-style: {{ section.settings.quote_font.style }};
      font-size: {{ section.settings.quote_font_size }}px;
      font-weight: {{ section.settings.quote_font_weight }};
      line-height: {{ section.settings.quote_line_height }}px;
      color: {{ section.settings.quote_color }};
      margin: 0 0 {{ section.settings.quote_margin_bottom }}px;

      max-width: {{ section.settings.global_content_width }}%;
      margin-top: {{ section.settings.global_margin_top }}%;
      margin-bottom: {{ section.settings.global_margin_bottom }}%;

    {% if section.settings.global_content_width < 100 %}
      margin-right: auto;
    {% endif %}
    }

    /* Author */
    .tslider-author-{{ section.id }} {
      font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
      font-style: {{ section.settings.body_font.style }};
      font-size: {{ section.settings.author_font_size }}px;
      font-weight: {{ section.settings.author_font_weight }};
      color: {{ section.settings.author_color }};
      margin-bottom: {{ section.settings.author_margin_bottom }}px;
      margin-top: -1%;
    }

    /* Verified badge */
    .tslider-verified-{{ section.id }} {
      display: flex;
      align-items: center;
      gap: 3px;
      font-size: {{ section.settings.verified_font_size }}px;
      color: {{ section.settings.verified_color }};
      font-family: {{ section.settings.body_font.family }}, {{ section.settings.body_font.fallback_families }};
      font-style: {{ section.settings.body_font.style }};
    }

    .tslider-verified-{{ section.id }} svg {
      width: {{ section.settings.verified_icon_size }}px;
      height: {{ section.settings.verified_icon_size }}px;
      flex-shrink: 0;
    }

    /* Pagination dots */
    .tslider-pagination-{{ section.id }} {
      display: flex;
      align-items: center;
      gap: {{ section.settings.dot_gap }}px;
      margin-top: {{ section.settings.dots_margin_top }}%;
      margin-left: {{ section.settings.dots_margin_left }}%;
      justify-content: {{ section.settings.dots_alignment }};
      position: relative;
      z-index: 10;
    }

    .tslider-dot-{{ section.id }} {
      width: {{ section.settings.dot_size }}px;
      height: {{ section.settings.dot_size }}px;
      border-radius: 50%;
      background: {{ section.settings.dot_inactive_color }};
      border: none;
      padding: 0;
      cursor: pointer;
      transition: background 0.25s, transform 0.25s;
    }

    .tslider-dot-{{ section.id }}.active {
      background: {{ section.settings.dot_active_color }};
      transform: scale(1.25);
    }

    /* Responsive */
    @media (max-width: {{ section.settings.mobile_breakpoint }}px) {
      .tslider-inner-{{ section.id }} {
        flex-direction: column;
        gap: 24px;
      }
      .tslider-image-col-{{ section.id }} {
        flex: none;
        width: auto;
        margin-left: -40%;
        transform: scaleX(-1);
      }
      .tslider-img-wrap-{{ section.id }} {
        width: {{ section.settings.image_width_mobile }}px;
        height: {{ section.settings.image_height_mobile }}px;
      }
      .tslider-fixed-bg-{{ section.id }} {
        display: none;
      }
      .tslider-content-col-{{ section.id }} {
        margin-left: 12%;
      }
    }
    .tslider-fixed-bg-{{ section.id }} {
        position: absolute;
        top: 0;
        right: 0;
        width: 370px; 
        height: 470px; 
        z-index: 0; 
        pointer-events: none; 
        overflow: hidden;
    }

  .tslider-fixed-bg-{{ section.id }} img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

  .tslider-wrap-{{ section.id }} {
    position: relative;
    z-index: 2;
  }
</style>

<section class="tslider-section-{{ section.id }}">
  {%- if section.settings.fixed_bg_image != blank -%}
    <div class="tslider-fixed-bg-{{ section.id }}">
      {{
        section.settings.fixed_bg_image
        | image_url: width: 370
        | image_tag: loading: 'lazy', width: 370, height: 470, alt: '', widths: '370'
      }}
    </div>
  {%- endif -%}
  <div class="tslider-wrap-{{ section.id }}">
    <div class="tslider-inner-{{ section.id }}">
      {%- comment -%} IMAGE COLUMN — shows image from active slide or fallback {%- endcomment -%}
      <div class="tslider-image-col-{{ section.id }}">
        <div class="tslider-img-wrap-{{ section.id }}" id="tslider-imgwrap-{{ section.id }}">
          {%- if section.blocks.size > 0 -%}
            {%- assign first_block = section.blocks | first -%}
            {%- if first_block.settings.photo != blank -%}
              <img
                id="tslider-img-{{ section.id }}"
                src="{{ first_block.settings.photo | image_url: width: 600 }}"
                alt="{{ first_block.settings.author | escape }}"
                width="{{ first_block.settings.photo.width }}"
                height="{{ first_block.settings.photo.height }}"
                loading="lazy"
              >
            {%- else -%}
              <div class="tslider-img-placeholder-{{ section.id }}" id="tslider-img-{{ section.id }}">No image</div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} CONTENT COLUMN {%- endcomment -%}
      <div class="tslider-content-col-{{ section.id }}">
        {%- if section.settings.overline != blank -%}
          <p class="tslider-overline-{{ section.id }}">{{ section.settings.overline }}</p>
        {%- endif -%}

        {%- comment -%} Stars + review count {%- endcomment -%}
        <div class="tslider-stars-row-{{ section.id }}">
          <div class="tslider-stars-{{ section.id }}">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 20 20" fill="{{ section.settings.star_color }}" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.32L10 13.27l-4.77 2.44.91-5.32L2.27 6.62l5.34-.78z"/>
              </svg>
            {%- endfor -%}
          </div>
          {%- if section.settings.review_count != blank -%}
            <span class="tslider-review-count-{{ section.id }}">{{ section.settings.review_count }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Slides {%- endcomment -%}
        <div class="tslider-slides-outer-{{ section.id }}">
          <div class="tslider-slides-{{ section.id }}" id="tslider-track-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <div class="tslider-slide-{{ section.id }}" {{ block.shopify_attributes }}>
                  {%- if block.settings.quote != blank -%}
                    <div class="tslider-quote-{{ section.id }}">{{ block.settings.quote }}</div>
                  {%- endif -%}
                  {%- if block.settings.author != blank -%}
                    <p class="tslider-author-{{ section.id }}">{{ block.settings.author }}</p>
                  {%- endif -%}
                  {%- if block.settings.show_verified -%}
                    <div class="tslider-verified-{{ section.id }}">
                      <svg
                        viewBox="0 0 20 20"
                        fill="{{ section.settings.verified_icon_color }}"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      <span>{{ block.settings.verified_label | default: 'Verified Purchase' }}</span>
                    </div>
                  {%- endif -%}
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        {%- comment -%} Pagination dots {%- endcomment -%}
        {%- if section.blocks.size > 1 -%}
          <div class="tslider-pagination-{{ section.id }}" id="tslider-dots-{{ section.id }}">
            {%- for block in section.blocks -%}
              {%- if block.type == 'testimonial' -%}
                <button
                  class="tslider-dot-{{ section.id }}{% if forloop.first %} active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  aria-label="Go to testimonial {{ forloop.index }}"
                ></button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      {%- comment -%} end content col {%- endcomment -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var sid = '{{ section.id }}';
    var autoplay = {{ section.settings.autoplay }};
    var autoplaySpeed = {{ section.settings.autoplay_speed }};

    var track = document.getElementById('tslider-track-' + sid);
    var dotsWrap = document.getElementById('tslider-dots-' + sid);
    var imgEl = document.getElementById('tslider-img-' + sid);

    if (!track) return;

    var slides = track.querySelectorAll('.tslider-slide-' + sid);
    var dots = dotsWrap ? dotsWrap.querySelectorAll('.tslider-dot-' + sid) : [];
    var current = 0;
    var timer = null;

    // Collect per-slide image URLs from Liquid
    var slideImages = [
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          {%- if block.settings.photo != blank -%}
            '{{ block.settings.photo | image_url: width: 600 }}',
          {%- else -%}
            '',
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    ];

    function goTo(index) {
      current = index;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';

      // Update image
      if (imgEl) {
        var src = slideImages[current];
        if (src) {
          if (imgEl.tagName === 'IMG') {
            imgEl.src = src;
          } else {
            // placeholder div — swap to img
            var newImg = document.createElement('img');
            newImg.id = imgEl.id;
            newImg.src = src;
            newImg.alt = '';
            newImg.style.cssText = 'width:100%;height:100%;object-fit:cover;object-position:center;display:block;';
            imgEl.parentNode.replaceChild(newImg, imgEl);
            imgEl = newImg;
          }
        }
      }

      // Update dots
      dots.forEach(function (d, i) {
        d.classList.toggle('active', i === current);
      });
    }

    // Dot clicks
    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        clearInterval(timer);
        goTo(parseInt(this.dataset.index));
        if (autoplay) startAuto();
      });
    });

    function startAuto() {
      timer = setInterval(function () {
        goTo((current + 1) % slides.length);
      }, autoplaySpeed);
    }

    if (autoplay && slides.length > 1) startAuto();
  })();
</script>

{% schema %}
{
  "name": "Testimonials Slider",
  "tag": "section",
  "class": "section-testimonials-slider",
  "max_blocks": 20,
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "color",
      "id": "bg_color",
