
<div 
  class="underlying-image-block" 
  id="block--{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.image != blank -%}
    {{ block.settings.image | image_url: width: 1200 | image_tag: 
      loading: 'lazy', 
      class: 'underlying-image-block__img' 
    }}
  {%- else -%}
    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
  {%- endif -%}
</div>

{%- style -%}
  #block--{{ block.id }} {
    position: absolute !important;
    z-index: -1;
    pointer-events: none;
    width: {{ block.settings.width | default: '100%' }};
    height: {{ block.settings.height | default: 'auto' }};
    
    margin-top: {{ block.settings.m_top }}% !important;
    margin-bottom: {{ block.settings.m_bottom }}% !important;
    margin-left: {{ block.settings.m_left }}% !important;
    margin-right: {{ block.settings.m_right }}% !important;
    
    inset: 0;
    display: block;
  }

  @media screen and (max-width: 767px) {
    #block--{{ block.id }} {
      display: none !important;
    }
  }

  #block--{{ block.id }} .underlying-image-block__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Underlying Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Select Image"
    },
    {
      "type": "text",
      "id": "width",
      "label": "Width (e.g., 50% or 200px)",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "height",
      "label": "Height (e.g., auto or 300px)",
      "default": "auto"
    },
    {
      "type": "header",
      "content": "Margins (%)"
    },
    {
      "type": "range",
      "id": "m_top",
      "min": -100, "max": 100, "step": 2, "unit": "%",
      "label": "Margin Top", "default": 0
    },
    {
      "type": "range",
      "id": "m_bottom",
      "min": -100, "max": 100, "step": 2, "unit": "%",
      "label": "Margin Bottom", "default": 0
    },
    {
      "type": "range",
      "id": "m_left",
      "min": -100, "max": 100, "step": 2, "unit": "%",
      "label": "Margin Left", "default": 0
    },
    {
      "type": "range",
      "id": "m_right",
      "min": -100, "max": 100, "step": 2, "unit": "%",
      "label": "Margin Right", "default": 0
    }
  ],
  "presets": [
    {
      "name": "underlying",
      "category": "underlying"
    }
  ]
}
{% endschema %}