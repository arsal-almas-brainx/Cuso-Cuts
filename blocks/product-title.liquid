          "value": "fit-content",
          "label": "t:options.fit"
        },
        {
          "value": "100%",
          "label": "t:options.fill"
        },
        {
          "value": "custom",
          "label": "Custom Width"
        }
      ],
      "default": "fit-content",
      "visible_if": "{{ block.settings.custom_style }}"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "Custom Width (%)",
      "min": 10,
      "max": 150,
      "step": 2,
      "unit": "%",
      "default": 50,
      "visible_if": "{{ block.settings.custom_style and block.settings.width == 'custom' }}"
    },
    {
      "type": "select",
      "id": "max_width",
      "label": "t:settings.max_width",
      "options": [
        {
          "value": "narrow",
          "label": "t:options.narrow"
        },
        {
          "value": "normal",
          "label": "t:options.normal"
        },
        {
          "value": "none",
          "label": "t:options.none"
        }
      ],
      "default": "normal",
      "visible_if": "{{ block.settings.custom_style }}"
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "t:settings.alignment",
      "default": "left",
      "visible_if": "{{ block.settings.custom_style and block.settings.width == '100%' }}"
    },
    {
      "type": "header",
      "content": "t:content.typography",
      "visible_if": "{{ block.settings.custom_style }}"
    },
    {
      "type": "select",
      "id": "type_preset",
      "label": "t:settings.preset",
