{% liquid
  assign block_settings = block.settings
  assign logo_image = block_settings.image | default: settings.logo

  assign alt_text_fallback = 'accessibility.home_logo_alt' | t: store_name: shop.name
  assign logo_alt = logo_image.alt | default: alt_text_fallback
%}

<a
  href="{{ block_settings.link | default: routes.root_url }}"
  class="header-logo custom-logo-wrapper"
  style="
    --logo-height: {{ block_settings.logo_height }}px;
    --logo-width: {{ block_settings.logo_width }}px;
    --logo-height-mobile: {{ block_settings.logo_height_mobile }}px;
    --logo-width-mobile: {{ block_settings.logo_width_mobile }}px;
    --logo-margin-top: {{ block_settings.margin_top }}%;
    --logo-margin-left: {{ block_settings.margin_left }}%;
    --logo-margin-left-mobile: {{ block_settings.margin_left_mobile }}%;
  "
  {{ block.shopify_attributes }}
>
  {% if logo_image != blank %}
    <div class="header-logo__image-container">
      {{
        logo_image
        | image_url: width: 1000
        | image_tag: class: 'header-logo__custom-img', widths: '200, 400, 600, 800, 1000', alt: logo_alt
      }}
    </div>
  {% else %}
    <span class="h2">{{ shop.name }}</span>
  {% endif %}
</a>

{% stylesheet %}
  .custom-logo-wrapper {
    display: flex;
    align-items: center;
    text-decoration: none;
    position: relative;
    margin-top: var(--logo-margin-top);
    margin-left: var(--logo-margin-left);
  }

  .header-logo__custom-img {
    display: block;
    height: var(--logo-height);
    width: var(--logo-width);
    object-fit: contain;
    max-width: 100vw;
  }

  @media screen and (max-width: 749px) {
    .header-logo__custom-img {
      height: var(--logo-height-mobile);
      width: var(--logo-width-mobile);
      max-height: none; 
    }
    .custom-logo-wrapper {
      margin-top: 0;
      /* Apply the new mobile margin setting here */
      margin-left: var(--logo-margin-left-mobile);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Logo",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Logo Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Logo Link",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Desktop Sizing"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo Height",
      "min": 10,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo Width",
      "min": 50,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 150
    },
    {
      "type": "header",
      "content": "Mobile Sizing & Position"
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Mobile Logo Height",
      "min": 10,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "label": "Mobile Logo Width",
      "min": 50,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "margin_left_mobile",
      "label": "Mobile Margin Left",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 0
    },
    {
      "type": "header",
      "content": "Desktop Positioning (%)"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_left",
      "label": "Margin Left",
      "min": -50,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 0
    }
  ]
}
{% endschema %}